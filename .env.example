NODE_ENV=development

GRAPHQL_URI=https://localhost:3000/graphql

DB_URI=mongodb+srv://<user>:<password>@<cluster-host>/
DB_NAME=pos
DB_APP=pos

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET=<generate-a-unique-secret-per-environment>
NEXTAUTH_URL=https://localhost:3000

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET=<generate-a-unique-secret-per-environment>

NEXT_PUBLIC_CASH_ID=<payment-method-id>
NEXT_PUBLIC_ON_ACCOUNT_ID=<payment-method-id>
NEXT_PUBLIC_STORE_CREDIT_ID=<payment-method-id>
